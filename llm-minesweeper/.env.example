# API keys and Base URLs for the Minesweeper benchmark harness

# Vision Parser Model (e.g., Gemini 3.1 Pro or Gemini 1.5 Pro via OpenAI-compatible API)
VISION_API_KEY=your_gemini_api_key_here
VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
VISION_MODEL=gemini-3.1-pro-preview

# Solver Agent Model (e.g., GPT-4o, Gemini 2.5 Flash, etc. via OpenAI-compatible API)
AGENT_API_KEY=your_agent_api_key_here
AGENT_BASE_URL=https://api.openai.com/v1
AGENT_MODEL=gpt-4o

# Optional: ADB device serial (run 'adb devices' to find it). Leave empty to use the default device.
ADB_DEVICE_SERIAL=
