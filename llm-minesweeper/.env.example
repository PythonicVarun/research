# API Key and Endpoint Configuration for Single-Model Solver

# Vision/Solver Model (e.g., Gemini 3.1 Pro via OpenAI-compatible API)
VISION_API_KEY=your_gemini_api_key_here
VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
VISION_MODEL=gemini-3.1-pro-preview

# Optional: ADB device serial (run 'adb devices' to find it). Leave empty to use the default connected device.
ADB_DEVICE_SERIAL=
